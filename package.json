{
  "name": "node-printer",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "corepack pnpm run build:all",
    "release": "corepack pnpm run verify:release",
    "test-server": "node apps/test-server/server.mjs",
    "format": "prettier --write .",
    "verify": "corepack pnpm run verify:release",
    "verify:release": "corepack pnpm run verify:lint && corepack pnpm run verify:typecheck && corepack pnpm run verify:test && corepack pnpm run build && corepack pnpm run verify:pack",
    "verify:lint": "corepack pnpm -r --if-present lint",
    "verify:typecheck": "tsc -p tsconfig.json",
    "verify:test": "corepack pnpm -r --if-present test",
    "verify:pack": "corepack pnpm --filter @maxxuxx/node-printer pack:check",
    "build:all": "corepack pnpm run build:packages && corepack pnpm run build:test-server",
    "build:packages": "corepack pnpm -r --if-present build",
    "build:test-server": "vite build --config apps/test-server/vite.config.mjs",
    "lint": "corepack pnpm run verify:lint",
    "typecheck": "corepack pnpm run verify:typecheck",
    "test": "corepack pnpm run verify:test",
    "release:check": "corepack pnpm run verify:release",
    "release:publish": "corepack pnpm run release"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "qrcode-generator": "^2.0.4",
    "svelte": "^5.55.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
