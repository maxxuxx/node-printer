{
  "name": "node-printer",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "corepack pnpm run build:packages && corepack pnpm run build:test-server",
    "build:packages": "corepack pnpm -r --if-present build",
    "build:test-server": "vite build --config examples/printer-test-server/vite.config.mjs",
    "lint": "corepack pnpm -r --if-present lint",
    "release:check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build && corepack pnpm --filter @node-printer/printer-winspool pack:check",
    "test": "corepack pnpm -r --if-present test",
    "test-server": "node examples/printer-test-server/server.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "svelte": "^5.55.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
