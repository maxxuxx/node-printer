{
  "name": "@maxxuxx/node-printer",
  "version": "1.4.0",
  "description": "Unified entry point for ESC/POS receipt printer transports (serial, network, CUPS, Windows Spooler)",
  "license": "MIT",
  "homepage": "https://github.com/maxxuxx/node-printer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxxuxx/node-printer.git",
    "directory": "apps/printer"
  },
  "bugs": {
    "url": "https://github.com/maxxuxx/node-printer/issues"
  },
  "keywords": [
    "escpos",
    "receipt",
    "printer",
    "thermal-printer",
    "pos",
    "winspool",
    "cups",
    "serial",
    "tcp"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "prebuilds"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "lint": "eslint src test --max-warnings=0",
    "pack:check": "pnpm pack --dry-run",
    "prebuild:all": "npm run prebuild:x64 && npm run prebuild:ia32 && npm run prebuild:arm64 && npm run prebuild:serialport",
    "prebuild:arm64": "node scripts/prebuild-winspool.cjs arm64",
    "prebuild:check": "node scripts/check-prebuilds.cjs",
    "prebuild:ia32": "node scripts/prebuild-winspool.cjs ia32",
    "prebuild:serialport": "node scripts/prebuild-serialport.cjs",
    "prebuild:x64": "node scripts/prebuild-winspool.cjs x64",
    "prepack": "npm run prebuild:serialport && npm run prebuild:check",
    "prepublishOnly": "npm run build",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@serialport/stream": "^13.0.0",
    "iconv-lite": "^0.7.0"
  },
  "devDependencies": {
    "@serialport/bindings-cpp": "13.0.1"
  }
}
