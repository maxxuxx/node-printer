{
  "name": "@node-printer/winspool",
  "version": "1.0.0",
  "private": true,
  "description": "Windows Spooler RAW transport (native N-API) for printer packages",
  "license": "MIT",
  "homepage": "https://github.com/maxxuxx/node-printer#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxxuxx/node-printer.git",
    "directory": "apps/winspool"
  },
  "bugs": {
    "url": "https://github.com/maxxuxx/node-printer/issues"
  },
  "keywords": [
    "escpos",
    "receipt",
    "printer",
    "winspool",
    "windows",
    "native",
    "napi"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "prebuilds"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean --sourcemap --shims && tsc -p tsconfig.json --emitDeclarationOnly",
    "lint": "eslint src test --max-warnings=0",
    "pack:check": "npm run prebuild:check && pnpm pack --dry-run",
    "prebuild:all": "npm run prebuild:x64 && npm run prebuild:ia32 && npm run prebuild:arm64",
    "prebuild:check": "node -e \"const { readdirSync } = require('node:fs'); const missing = ['win32-x64','win32-ia32','win32-arm64'].filter((arch) => { try { return !readdirSync('prebuilds/' + arch).some((file) => file.endsWith('.node')); } catch { return true; } }).map((arch) => 'prebuilds/' + arch + '/*.node'); if (missing.length) { console.error('Missing winspool prebuilds:\\n' + missing.join('\\n')); process.exit(1); }\"",
    "prebuild:x64": "node scripts/prebuild.cjs x64",
    "prebuild:ia32": "node scripts/prebuild.cjs ia32",
    "prebuild:arm64": "node scripts/prebuild.cjs arm64",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@node-printer/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
